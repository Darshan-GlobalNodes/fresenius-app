# ──────────────────────────────────────────────────────────────────────────────
# Fresenius AI Assistant — Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# ── Google OAuth ──────────────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/
# 2. Create a project → APIs & Services → Credentials → Create OAuth 2.0 Client
# 3. Application type: Web application
# 4. Authorised redirect URIs: http://localhost:8000/auth/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# ── Authorised users (comma-separated email addresses) ───────────────────────
WHITELISTED_EMAILS=darshan.kholakiya@globalnodes.ai

# ── Session security ──────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: "anthropic" (default) or "bedrock"
LLM_PROVIDER=anthropic

# ── Anthropic API (if LLM_PROVIDER=anthropic) ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ── AWS Bedrock (if LLM_PROVIDER=bedrock) ────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1
AWS_SERVICE_NAME=bedrock-runtime
# Claude 3.5 Sonnet v2 requires the cross-region inference profile prefix (us./eu./ap.)
# NOT the bare model ID — on-demand throughput with bare IDs is no longer supported.
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# ── Tavily Search (optional — enhances search quality) ───────────────────────
TAVILY_API_KEY=tvly-...
